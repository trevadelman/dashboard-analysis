# Alpaca API Credentials
ALPACA_PUBLIC=your_api_key_here
ALPACA_SECRET=your_secret_key_here

# Trading Mode (true for paper trading, false for live)
PAPER_TRADING=true

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b-it-qat

# Risk Management
MAX_POSITIONS=5
RISK_PERCENTAGE=2.0

# Watchlist (comma-separated symbols)
WATCHLIST=SPY,QQQ,IWM

# Logging
LOG_LEVEL=INFO

# Dashboard (optional)
SECRET_KEY=change-this-in-production
